{
  "manifest_version": 2,
  "name": "Eztypr",
  "version": "1.0",
  "description": "Adds a red border to all webpages matching mozilla.org.",
  "icons": {
    "48": "icons/border-48.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "*://docs.google.com/*"
  ],
  "browser_action": {
    "default_title": "Eztypr",
    "default_popup": "popup/menu2.html"
  },
  "icons": {
    "32": "./.eztypr_logo_small.png",
    "64": "./.eztypr_logo_small_64.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@e0681d76-2029-11f1-b3aa-53e3adc9bb3a",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}

